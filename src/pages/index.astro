---
import '../globals.css';
import Hero from '@/components/Hero'
import About from '@/components/About'
import Projects from '@/components/Projects'
import Contact from '@/components/Contact'
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Software engineer, tutor, and athlete based in New York City." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>Daniel Iofin - Software Engineer</title>
  </head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-G2YJC6SSGT"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-G2YJC6SSGT');
  </script>
  <body class="bg-background text-foreground antialiased">
    <main class="min-h-screen bg-background pb-24">
      <Hero client:load />
      <About client:load />
      <Projects client:load />
      <Contact client:load />
    </main>
  </body>
</html>
